        896,
        96
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const request = $('🔍 Webhook Web Search').first().json;\nconst verifiedUser = $('🔐 Verify JWT').first().json;\nconst body = request.body || {};\nconst cfg = $input.first().json;\nconst query = typeof body.query === 'string' ? body.query.trim() : '';\nconst searchMode = typeof body.search_mode === 'string' ? body.search_mode.trim() : 'general';\nconst rawDomains = Array.isArray(body.include_domains) ? body.include_domains : [];\nconst maxResults = Math.min(typeof body.max_results === 'number' ? body.max_results : Number(cfg.max_results || 10), 20);\nif (!query) return [{ json: { error: true, status: 400, message: 'Thiếu query' } }];\nif (query.length > Number(cfg.max_query_length || 2000)) return [{ json: { error: true, status: 400, message: 'query vượt quá độ dài cho phép' } }];\nconst modePresets = {\n  guideline: ['who.int','ich.org','picscheme.org','ema.europa.eu','fda.gov','hsa.gov.sg','moh.gov.vn','dav.gov.vn','ispe.org','pda.org'],\n  literature: ['ncbi.nlm.nih.gov','pubmed.ncbi.nlm.nih.gov','europepmc.org'],\n  forum: [], general: []\n};\nconst validModes = Object.keys(modePresets);\nconst mode = validModes.includes(searchMode) ? searchMode : 'general';\nconst domains = rawDomains.length > 0 ? rawDomains : (modePresets[mode] || []);\nreturn [{ json: { error: false, user_id: String(verifiedUser.id || ''), user_email: String(verifiedUser.email || ''), query, search_mode: mode, include_domains: domains, max_results: maxResults, snippet_max: Number(cfg.snippet_max || 800) } }];"
      }
    },
