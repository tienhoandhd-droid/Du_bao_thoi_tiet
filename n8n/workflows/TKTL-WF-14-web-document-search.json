    {
      "id": "412c1c4b-f481-4381-b7d6-98c2b69b0372",
      "name": "⚡ Process Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2016,
        96
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const parsed = $('Parse + Validate').first().json;\nconst raw = $input.first().json;\nconst results = Array.isArray(raw.results) ? raw.results : [];\nconst snippetMax = Number(parsed.snippet_max || 800);\nconst trustConfig = [\n  { level: 4, badge: '🔵 Cơ quan quản lý', domains: ['who.int','ich.org','picscheme.org','ema.europa.eu','fda.gov','hsa.gov.sg','moh.gov.vn','dav.gov.vn','tga.gov.au','pmda.go.jp'] },\n  { level: 3, badge: '🟢 Tổ chức uy tín',  domains: ['ispe.org','pda.org','usp.org','edqm.eu','ncbi.nlm.nih.gov','pubmed.ncbi.nlm.nih.gov','europepmc.org','pharmaceutical-technology.com'] },\n  { level: 2, badge: '🟡 Chuyên ngành',    domains: ['drugs.com','rxlist.com','webmd.com','medscape.com','pharmacytimes.com'] }\n];\nfunction getTrust(url) {\n  try {\n    const host = new URL(url).hostname.replace(/^www\\./, '');\n    for (const tier of trustConfig) {\n      if (tier.domains.some(d => host === d || host.endsWith('.' + d))) return { trust_level: tier.level, trust_badge: tier.badge, source_domain: host };\n    }\n    return { trust_level: 1, trust_badge: '⚪ Nguồn khác', source_domain: host };\n  } catch { return { trust_level: 1, trust_badge: '⚪ Nguồn khác', source_domain: '' }; }\n}\nconst enriched = results.map((r, i) => ({ rank: i + 1, title: String(r.title || ''), url: String(r.url || ''), content: String(r.content || '').slice(0, snippetMax), relevance_score: Number(r.score || 0), published_date: r.published_date || null, ...getTrust(r.url || '') }));\nenriched.sort((a, b) => b.trust_level !== a.trust_level ? b.trust_level - a.trust_level : b.relevance_score - a.relevance_score);\nenriched.forEach((r, i) => { r.rank = i + 1; });\nreturn [{ json: { results: enriched, total: enriched.length, query: parsed.query, search_mode: parsed.search_mode, user_id: parsed.user_id, user_email: parsed.user_email } }];"
      }
    },
