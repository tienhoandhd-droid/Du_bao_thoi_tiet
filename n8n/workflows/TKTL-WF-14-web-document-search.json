        "jsCode": "const d = $input.first().json;\nconst body = { query: d.query, search_depth: 'advanced', include_answer: false, include_raw_content: false, max_results: d.max_results, topic: 'general' };\nif (d.include_domains && d.include_domains.length > 0) body.include_domains = d.include_domains;\nreturn [{ json: { ...d, tavily_body: JSON.stringify(body) } }];"
