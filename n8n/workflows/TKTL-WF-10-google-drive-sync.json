    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst base64Data = item.json.file_content_base64;\nconst fileName = item.json.file_name;\nconst mimeType = item.json.mime_type || 'application/pdf';\nconst folderId = '15Fo7BqcDQJqzPPuqds-AuScqeNqOyLUz';\n\nconst buffer = Buffer.from(base64Data, 'base64');\nif (buffer.length > 10 * 1024 * 1024) {\n  throw new Error('File quá lớn: ' + buffer.length + ' bytes (tối đa 10MB)');\n}\n\nconst boundary = 'gmp_' + Date.now();\nconst metadata = JSON.stringify({ name: fileName, parents: [folderId], mimeType: mimeType });\nconst part1 = Buffer.from(\n  `--${boundary}\\r\\nContent-Type: application/json; charset=UTF-8\\r\\n\\r\\n${metadata}\\r\\n--${boundary}\\r\\nContent-Type: ${mimeType}\\r\\n\\r\\n`,\n  'utf-8'\n);\nconst part2 = buffer;\nconst close = Buffer.from(`\\r\\n--${boundary}--`, 'utf-8');\nconst multipartBuffer = Buffer.concat([part1, part2, close]);\n\nconst contentType = `multipart/related; boundary=\"${boundary}\"`;\nconst binaryData = await this.helpers.prepareBinaryData(multipartBuffer, 'drive_upload.bin', contentType);\n\nreturn [{\n  json: {\n    file_name: fileName,\n    mime_type: mimeType,\n    user_id: item.json.user_id,\n    file_size: buffer.length\n  },\n  binary: {\n    driveBody: binaryData\n  }\n}];"
      },
