        "jsCode": "const raw = $input.first().json;\nconst detail = raw.error?.message || raw.message || 'Supabase REST từ chối yêu cầu';\nreturn [{ json: { error: true, status: 502, message: 'Tệp đã lên Drive nhưng không ghi được drive_sync_log: ' + detail } }];"
      },
