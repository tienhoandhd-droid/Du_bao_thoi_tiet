    {
      "parameters": {
        "jsCode": "const request = $('Webhook Drive Sync').first().json;\nconst verifiedUser = $('🔐 Verify JWT').first().json;\nconst body = request.body || {};\n\nconst fileName = typeof body.file_name === 'string' ? body.file_name.trim() : '';\nconst fileContentBase64 = typeof body.file_content_base64 === 'string' ? body.file_content_base64.trim() : '';\nconst mimeType = typeof body.mime_type === 'string' ? body.mime_type.trim() : 'application/pdf';\n\nif (!fileName || !fileContentBase64) {\n  return [{ json: { error: true, status: 400, message: 'Thiếu file_name hoặc file_content_base64' } }];\n}\n\nif (!verifiedUser.id) {\n  return [{ json: { error: true, status: 401, message: 'Không lấy được user.id từ Verify JWT' } }];\n}\n\nconst forbiddenChars = ['/', '\\\\', '..', '\u0000', '*', '?', '[', ']', '{', '}'];\nif (forbiddenChars.some(c => fileName.includes(c)) || fileName.length > 255) {\n  return [{ json: { error: true, status: 400, message: 'file_name không hợp lệ' } }];\n}\n\nconst allowedMimeTypes = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document', 'text/plain', 'image/png', 'image/jpeg'];\nif (!allowedMimeTypes.includes(mimeType)) {\n  return [{ json: { error: true, status: 400, message: 'mime_type không được hỗ trợ. Chấp nhận: PDF, Word, TXT, PNG, JPEG' } }];\n}\n\nconst estimatedBytes = Math.ceil(fileContentBase64.length * 0.75);\nif (estimatedBytes > 10 * 1024 * 1024) {\n  return [{ json: { error: true, status: 413, message: 'File quá lớn (tối đa 10MB)' } }];\n}\n\nreturn [{ json: { error: false, user_id: verifiedUser.id, file_name: fileName, file_content_base64: fileContentBase64, mime_type: mimeType } }];"
      },
