    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\n// Nếu là response thành công từ Drive (có id, không có error) → bỏ qua\nif (raw.id && !raw.error) {\n  return [];\n}\nconst errMsg = raw.error?.message || raw.message || 'Google Drive từ chối yêu cầu';\nconst errBody = JSON.stringify(raw.error?.response?.body || raw.error || raw);\nreturn [{ json: { error: true, status: 502, message: 'GD403: ' + errMsg + ' | body: ' + errBody } }];"
      },
