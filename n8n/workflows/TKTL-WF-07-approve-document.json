    {
      "parameters": {
        "jsCode": "// Parse + decode JWT\nconst headers = $('Webhook Approve').first().json.headers || {};\nconst body = $('Webhook Approve').first().json.body || {};\n\nconst authHeader = headers.authorization || headers.Authorization || '';\nconst token = authHeader.replace('Bearer ', '');\nif (!token) return [{ json: { error: true, message: 'Thiếu token', status: 401 } }];\n\nlet userId = null;\ntry {\n  const payload = JSON.parse(Buffer.from(token.split('.')[1], 'base64').toString());\n  userId = payload.sub;\n  if (!userId) throw new Error('Không có user ID');\n} catch (e) {\n  return [{ json: { error: true, message: 'Token không hợp lệ', status: 401 } }];\n}\n\nif (!body.document_id) {\n  return [{ json: { error: true, message: 'Thiếu document_id', status: 400 } }];\n}\n\nreturn [{ json: {\n  error: false,\n  user_id: userId,\n  document_id: body.document_id,\n  action: body.action || 'approve',\n  notes: body.notes || ''\n}}];"
      },
