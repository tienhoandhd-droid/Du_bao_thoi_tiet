      "parameters": {
        "jsCode": "// Chỉ qa_manager hoặc admin mới được duyệt\nconst roles = $input.all().map(item => item.json.role_name);\nconst prevData = $('Parse + JWT').first().json;\n\nif (!roles.some(r => ['admin', 'qa_manager'].includes(r))) {\n  return [{ json: { error: true, message: 'Chỉ QA Manager hoặc Admin mới được duyệt tài liệu cho AI', status: 403 } }];\n}\n\n// Map action → new_status\nconst statusMap = {\n  'approve': 'approved_for_ai_use',\n  'review': 'reviewed',\n  'supersede': 'superseded',\n  'archive': 'archived',\n  'reject': 'indexed'\n};\nconst newStatus = statusMap[prevData.action] || 'approved_for_ai_use';\n\nreturn [{ json: {\n  ...prevData,\n  primary_role: roles[0],\n  new_status: newStatus,\n  approve_sql: `SELECT update_document_status('${prevData.document_id}'::uuid, '${newStatus}'::document_status, '${prevData.user_id}'::uuid, '${roles[0]}');`\n}}];"
      },
