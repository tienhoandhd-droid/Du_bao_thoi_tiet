    "legal_owner_decision_required_before_production": true,
    "sbom_and_notice_required": true
  },
  "runtime_preflight": {
    "python_supported": "3.10-3.13",
    "minimum_ram_gib": 16,
    "recommended_ram_gib": 32,
    "minimum_free_disk_gib": 20,
    "isolated_environment_required": true,
    "model_download_is_separate_action": true,
    "resource_metrics": [
      "peak_rss_bytes",
      "wall_time_ms",
      "input_bytes",
      "output_bytes",
      "model_cache_hit",
      "cleanup_residue_bytes"
    ]
  },
  "job_boundary": {
