      "raw_sha256",
      "page_window_start",
      "page_window_end",
      "parser_lock_hash"
    ],
    "one_file_per_job": true,
    "default_page_window": 10,
    "reconcile_output_hash_before_retry": true,
    "lost_worker_state": "RETRYABLE_LOST_WORKER_STATE",
    "duplicate_production_write_allowed": false
  },
  "n8n_boundary": {
    "role": "MANIFEST_AND_RESULT_REFERENCE_ORCHESTRATOR",
