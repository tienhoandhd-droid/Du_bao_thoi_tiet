      "pipeline",
      "hybrid-engine"
    ],
    "forbid_latest_tag": true,
    "llm_aided_config_enabled": false,
    "external_document_upload_allowed": false,
    "private_local_worker_required": true
  },
  "license_gate": {
    "license_name": "MinerU Open Source License",
    "apache_2_based_with_additional_terms": true,
